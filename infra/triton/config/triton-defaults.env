# Triton director shared defaults
#
# Sourced by both:
#   - the runner scripts in infra/triton/scripts/
#   - the installed copy at /data/triton/config/triton-defaults.env, which
#     systemd units pick up via EnvironmentFile=
#
# Edit /data/triton/config/triton-defaults.env on the host to override these
# values for a specific deployment. The repo copy is the canonical defaults.
# See ADR-0014 (Triton director shared host service) and
# ADR-0012 (/data/<service>/ host layout convention).

# Container image. Pinned to the verified-good Triton + vLLM tag from NGC.
# Update via `docker pull` and bump this value when validating a new release.
TRITON_IMAGE=nvcr.io/nvidia/tritonserver:26.03-vllm-python-py3

# Where the model repository lives on the host.
# Read-only inside Triton containers; writes are the host operator's job
# via a separate model-download workflow (see Phase 1).
TRITON_MODEL_REPO=/data/triton/models

# Where Triton container logs are written on the host.
TRITON_LOG_DIR=/data/triton/logs

# Verbosity. 0 = info, 1 = verbose. Bump to 1 when debugging a load failure.
TRITON_LOG_VERBOSE=0
