# GemmaForge VM configuration — copy to config.env and edit as needed.
# config.env is gitignored; this example is committed as a template.

# Root directory for VM state (libvirt pool, snapshots, keys, tofu state).
VM_ROOT=/data/vm/gemma-forge

# Path to the Rocky 9 GenericCloud qcow2 image.
ROCKY9_IMAGE=${VM_ROOT}/pool/Rocky-9-GenericCloud.latest.x86_64.qcow2

# SSH key for the adm-forge service account on the VM.
SSH_KEY=${VM_ROOT}/keys/adm-forge
SSH_PUBKEY=${VM_ROOT}/keys/adm-forge.pub
