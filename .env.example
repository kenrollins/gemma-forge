# GemmaForge runtime configuration template.
#
# Copy to `.env` at the repo root and fill in real values. The `.env`
# file is gitignored and must never be committed. Rotate these
# credentials on any credential leak.
#
# This template covers the GemmaForge-scoped compose stack only. It
# does NOT cover host-level services (Triton director, Supabase, etc.)
# that run outside this compose project.

# =====================================================================
# Triton inference director (existing, unchanged)
# =====================================================================
# Override if the Triton director runs on a non-default host/port.
# TRITON_DIRECTOR_URL=http://host.containers.internal:8000
# TRITON_MODEL_REPO=/data/triton/models

# =====================================================================
# Memory tier — Postgres
# =====================================================================
# Superuser credentials (administrative use only; application code
# connects as the 'forge' role created by postgres-init/01-*.sql).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM

# Application credentials (must match the role created in
# infra/memory/postgres-init/01-create-databases.sql). After first
# boot, connect as postgres and run:
#   ALTER ROLE forge WITH PASSWORD '...';
# then update this value.
POSTGRES_FORGE_PASSWORD=CHANGE_ME_AT_BOOTSTRAP

# Host port for Postgres. Default 5432 is occupied on the XR7620 by
# the Supabase stack, so GemmaForge binds to 5433. Adjust if your
# host layout differs.
POSTGRES_HOST_PORT=5433

# =====================================================================
# Memory tier — Neo4j (Graphiti-on-Neo4j)
# =====================================================================
# Initial admin password. Set to a strong random value before first
# bring-up; Neo4j rejects the default "neo4j" password on first login.
NEO4J_PASSWORD=CHANGE_ME_STRONG_RANDOM

# Host ports. Defaults (7474 HTTP, 7687 Bolt) are free on the reference
# XR7620. If a future host has them occupied, pick alternatives and
# update infra/memory/README.md's port table.
NEO4J_HTTP_HOST_PORT=7474
NEO4J_BOLT_HOST_PORT=7687

# Heap and page cache sizing. Modest defaults suitable for a
# single-skill working set. Revisit when the second skill lands.
NEO4J_HEAP_INITIAL=1G
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G
