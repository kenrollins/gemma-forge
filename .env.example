# GemmaForge runtime configuration template.
#
# Copy to `.env` at the repo root and fill in real values. The `.env`
# file is gitignored and must never be committed. Rotate these
# credentials on any credential leak.
#
# This template covers the GemmaForge-scoped compose stack. Relational
# database state lives INSIDE the existing Supabase Postgres on this
# host; see tools/bootstrap_database.sh and tools/bootstrap_skill.sh
# for the one-time setup.

# =====================================================================
# Triton inference director (existing, unchanged)
# =====================================================================
# Override if the Triton director runs on a non-default host/port.
# TRITON_DIRECTOR_URL=http://host.containers.internal:8000
# TRITON_MODEL_REPO=/data/triton/models

# =====================================================================
# Memory tier — Postgres (shared with existing Supabase)
# =====================================================================
# Connection target for the harness and dashboard. The reference host
# exposes Supabase's pooler on 127.0.0.1:5432 (session mode) and
# 127.0.0.1:6543 (transaction mode). We use session mode so prepared
# statements and advisory locks behave predictably.
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=gemma_forge

# Admin credentials are only needed for the one-time bootstrap
# (creating the gemma_forge database, the forge_admin role, and per-skill
# schemas + roles). The bootstrap scripts read Supabase's own .env
# directly from /data/docker/supabase/.env, so these variables are
# OPTIONAL in this file and default to unused. Setting them here lets
# you override the discovery path.
# PG_ADMIN_ENV=/data/docker/supabase/.env

# Per-skill application role passwords. Generated at bootstrap time
# by tools/bootstrap_skill.sh and written back here. Runtime code
# connects as forge_<skill>, NOT as the admin role.
PG_FORGE_STIG_ROLE=forge_stig
PG_FORGE_STIG_PASSWORD=SET_BY_BOOTSTRAP_SKILL

# =====================================================================
# Memory tier — Neo4j (Graphiti-on-Neo4j)
# =====================================================================
# Initial admin password. Set to a strong random value before first
# bring-up; Neo4j rejects the default "neo4j" password on first login.
NEO4J_PASSWORD=CHANGE_ME_STRONG_RANDOM

# Host ports. Defaults (7474 HTTP, 7687 Bolt) are free on the reference
# XR7620. If a future host has them occupied, pick alternatives and
# update infra/memory/README.md's port table.
NEO4J_HTTP_HOST_PORT=7474
NEO4J_BOLT_HOST_PORT=7687

# Heap and page cache sizing. Modest defaults suitable for a
# single-skill working set. Revisit when the second skill lands.
NEO4J_HEAP_INITIAL=1G
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G
